#!/usr/bin/env python3
"""kb-kill-tray - StatusNotifierItem (tray) icon for the kb-kill service.

Shows whether each kb-kill group is disabled (killed) or active, and lets you
toggle a group by clicking its menu entry. Talks to the kb-kill service over its
Unix control socket (see `control_socket_path` in `kb-kill-daemon`).

Runs as its own process so a GUI hiccup can never affect keyboard handling. Uses
the AppIndicator / StatusNotifierItem D-Bus protocol, which works on COSMIC and
KDE natively, and on GNOME with the AppIndicator shell extension installed.

Requires: PyGObject (`gi`) with Gtk 3.0 and AyatanaAppIndicator3.
"""

# gi (PyGObject) ships no type stubs, so pyright cannot resolve it or the dynamic
# gi.repository imports; turn off the missing-import check for this file.
# pyright: reportMissingImports=false

import json
import os
import shutil
import socket
import subprocess
import sys

import gi

gi.require_version("Gtk", "3.0")
try:
    gi.require_version("AyatanaAppIndicator3", "0.1")
    from gi.repository import AyatanaAppIndicator3 as AppIndicator3
except (ValueError, ImportError):
    try:
        gi.require_version("AppIndicator3", "0.1")
        from gi.repository import AppIndicator3
    except (ValueError, ImportError):
        sys.stderr.write(
            "kb-kill-tray: AppIndicator typelib not found.\n"
            "  Debian/Ubuntu/Pop: sudo apt install gir1.2-ayatanaappindicator3-0.1\n"
            "  Arch             : sudo pacman -S libayatana-appindicator\n"
        )
        sys.exit(1)

from gi.repository import GLib, Gtk  # noqa: E402

APP_ID = "kb-kill"
ICON_AWAKE = "kb-kill-awake"
ICON_KILLED = "kb-kill-killed"
RECONNECT_SECONDS = 2


def icon_dir() -> str | None:
    """Locate the tray icons. Prefer icons shipped in the project tree (this
    script lives in scripts/, the icons in the project root's icons/), then a
    system install, then the user config."""
    here = os.path.dirname(os.path.realpath(__file__))
    for candidate in (
        os.path.join(here, "icons"),
        os.path.join(here, os.pardir, "icons"),  # scripts/ -> ../icons
        "/usr/local/share/kb-kill/icons",  # install.sh (local source install)
        "/usr/share/kb-kill/icons",  # distro package (deb/rpm/AUR)
        os.path.expanduser("~/.config/kb-kill/icons"),
    ):
        if os.path.isdir(candidate):
            return candidate
    return None


def socket_path() -> str:
    """Where the daemon's control socket lives. Must stay in sync with the
    daemon's control_socket_path() and kb-kill-push's socket_path() - the same
    candidate set in the same order."""
    candidates = ["/run/kb-kill/control.sock"]
    base = os.environ.get("XDG_RUNTIME_DIR")
    if base:
        candidates.append(os.path.join(base, "kb-kill.sock"))
    candidates.append(f"/tmp/kb-kill-{os.getuid()}.sock")
    for c in candidates:
        if os.path.exists(c):
            return c
    # default to the system path even if not yet present (reconnect will retry)
    return candidates[0]


class Tray:
    def __init__(self) -> None:
        self.ind = AppIndicator3.Indicator.new(
            APP_ID, ICON_AWAKE, AppIndicator3.IndicatorCategory.HARDWARE
        )
        icons = icon_dir()
        if icons:
            self.ind.set_icon_theme_path(icons)
        self.ind.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
        self.ind.set_title("kb-kill")
        self.sock: socket.socket | None = None
        self.buf = b""
        self.groups: list[dict] = []
        self.connected = False
        self._render()  # initial "connecting" menu/icon
        self._connect()

    # -- connection ---------------------------------------------------------- #
    def _connect(self) -> bool:
        path = socket_path()
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        try:
            s.connect(path)
        except OSError:
            s.close()
            self.connected = False
            self._render()
            GLib.timeout_add_seconds(RECONNECT_SECONDS, self._reconnect)
            return False
        s.setblocking(False)
        self.sock = s
        self.buf = b""
        self.connected = True
        GLib.io_add_watch(
            s.fileno(), GLib.IO_IN | GLib.IO_HUP | GLib.IO_ERR, self._on_readable
        )
        self._send({"cmd": "status"})
        return True

    def _reconnect(self) -> bool:
        if not self.connected:
            self._connect()
        return False  # one-shot timer

    def _drop(self) -> None:
        if self.sock is not None:
            try:
                self.sock.close()
            except OSError:
                pass
        self.sock = None
        self.connected = False
        self._render()
        GLib.timeout_add_seconds(RECONNECT_SECONDS, self._reconnect)

    def _on_readable(self, fd: int, condition: int) -> bool:
        if condition & (GLib.IO_HUP | GLib.IO_ERR):
            self._drop()
            return False
        if self.sock is None:
            return False
        try:
            data = self.sock.recv(4096)
        except OSError:
            self._drop()
            return False
        if not data:
            self._drop()
            return False
        self.buf += data
        *lines, self.buf = self.buf.split(b"\n")
        for line in lines:
            line = line.strip()
            if not line:
                continue
            try:
                msg = json.loads(line)
            except ValueError:
                continue
            if msg.get("type") == "state":
                self.groups = msg.get("groups", [])
                self._render()
        return True

    def _send(self, obj: dict[str, str]) -> None:
        if self.sock is None:
            return
        try:
            self.sock.sendall((json.dumps(obj) + "\n").encode())
        except OSError:
            self._drop()

    # -- UI ------------------------------------------------------------------ #
    def _render(self) -> None:
        any_killed = any(g.get("killed") for g in self.groups)
        self.ind.set_icon_full(ICON_KILLED if any_killed else ICON_AWAKE, "kb-kill")
        if not self.connected:
            self.ind.set_title("kb-kill: connecting…")
        elif any_killed:
            killed = [g["name"] for g in self.groups if g.get("killed")]
            self.ind.set_title("kb-kill: disabled (" + ", ".join(killed) + ")")
        else:
            self.ind.set_title("kb-kill: all active")
        self.ind.set_menu(self._build_menu())

    def _build_menu(self) -> Gtk.Menu:
        menu = Gtk.Menu()
        if not self.connected:
            item = Gtk.MenuItem(label="Connecting to kb-kill service…")
            item.set_sensitive(False)
            menu.append(item)
        elif not self.groups:
            item = Gtk.MenuItem(label="No groups configured")
            item.set_sensitive(False)
            menu.append(item)
        else:
            for g in self.groups:
                killed = g.get("killed")
                # A tray menu is exported over the dbusmenu D-Bus protocol and
                # re-rendered by the shell, so it can't host arbitrary widgets
                # (a Gtk.Switch is dropped). A CheckMenuItem maps to dbusmenu's
                # checkmark toggle: it renders, and clicking anywhere on the row
                # toggles it. The check (on = keyboard active/awake) is the
                # switch. set_active() runs before connect(), so rebuilding the
                # menu from the daemon's broadcast never re-fires the handler.
                item = Gtk.CheckMenuItem(label=g["name"])
                item.set_active(not killed)
                item.connect("toggled", self._on_toggle, g["name"])
                menu.append(item)
        menu.append(Gtk.SeparatorMenuItem())
        open_item = Gtk.MenuItem(label="Open config…")
        open_item.connect("activate", self._on_open_config)
        menu.append(open_item)
        quit_item = Gtk.MenuItem(label="Quit tray")
        quit_item.connect("activate", lambda _i: Gtk.main_quit())
        menu.append(quit_item)
        menu.show_all()
        return menu

    def _on_toggle(self, _item: object, name: str) -> None:
        self._send({"cmd": "toggle", "group": name})

    # -- config --------------------------------------------------------------- #
    def _user_config_path(self) -> str:
        """This user's config file. Mirrors kb-kill-push's preferred location
        (KB_KILL_CONFIG override, else ~/.config/kb-kill/kb-kill.toml). We run
        as the user, so the environment / home are authoritative."""
        env = os.environ.get("KB_KILL_CONFIG")
        if env:
            return os.path.expanduser(env)
        return os.path.expanduser("~/.config/kb-kill/kb-kill.toml")

    def _default_config_source(self) -> str | None:
        """Where to seed a new user config from: the system default, then the
        example in the project tree (dev runs)."""
        here = os.path.dirname(os.path.realpath(__file__))
        for candidate in (
            "/etc/kb-kill/kb-kill.toml",
            os.path.join(here, os.pardir, "kb-kill.toml"),  # scripts/ -> ../
            os.path.join(here, "kb-kill.toml"),
        ):
            if os.path.isfile(candidate):
                return candidate
        return None

    def _on_open_config(self, _item: object) -> None:
        """Open the user's config in their default editor, creating it from the
        system default first if it does not exist yet. kb-kill-push notices the
        new/edited file and pushes it to the daemon on its own."""
        path = self._user_config_path()
        if not os.path.exists(path):
            try:
                os.makedirs(os.path.dirname(path), exist_ok=True)
                src = self._default_config_source()
                if src:
                    shutil.copyfile(src, path)
                else:
                    open(path, "a").close()  # nothing to seed from; empty file
            except OSError as e:
                sys.stderr.write(f"kb-kill-tray: cannot create {path}: {e}\n")
                return
        self._launch_editor(path)

    def _launch_editor(self, path: str) -> None:
        """Open path in the user's text editor. We resolve the handler ourselves
        rather than trust xdg-open: a .toml is application/toml, which usually
        has no association, and xdg-open's fallback can spuriously open the web
        browser (and sometimes the editor too). Prefer the toml handler, then
        the text/plain editor, and only fall back to xdg-open if neither is set.
        gtk-launch ships with the GTK3 this tray already requires."""
        desktop = ""
        for mime in ("application/toml", "text/plain"):
            try:
                out = subprocess.run(
                    ["xdg-mime", "query", "default", mime],
                    capture_output=True,
                    text=True,
                ).stdout.strip()
            except OSError:
                out = ""
            if out:
                desktop = out
                break
        cmd = ["gtk-launch", desktop, path] if desktop else ["xdg-open", path]
        try:
            subprocess.Popen(cmd, start_new_session=True)
        except OSError as e:
            sys.stderr.write(f"kb-kill-tray: could not open {path}: {e}\n")


def main() -> int:
    Tray()
    try:
        Gtk.main()
    except KeyboardInterrupt:
        pass
    return 0


if __name__ == "__main__":
    sys.exit(main())
