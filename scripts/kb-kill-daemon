#!/usr/bin/env python3
"""kb-kill-daemon - disable/enable a target keyboard on a global hotkey.

Runs as a long-lived root service. Any keyboard can press the configured *kill*
hotkey to disable (grab + eat all events from) the target keyboard(s). While
killed, every key from the target is swallowed EXCEPT the *wake* hotkey, so the
target keyboard can always wake itself - there is no way to lock yourself out.

Config arrives by PUSH, not from a file path: the daemon starts config-less and
each logged-in user's `kb-kill-push` sends their config (TOML text) over the
control socket. The daemon honours only the config of the user who currently
controls a seat (logind's ACTIVE_UID, graphical or TTY), and switches when the
active user switches - so it always follows whoever is actually at the machine.
`-c PATH` pins a file config live for ad-hoc testing; detect/monitor read a file.

Design notes
------------
* "Disable" means EVIOCGRAB on the target device: the kernel routes its events
  exclusively to us and we drop them. We only grab *while killed* - when awake
  the target is merely monitored (read, never grabbed), so normal typing is
  100% native and a crash of this service cannot break the keyboard.
* We never re-inject events, so there is no virtual device and no awake-path
  latency.
* Coexistence with input-remapper: input-remapper grabs the physical keyboard
  (e.g. /dev/input/event3) and forwards it to a virtual "...forwarded" device.
  Mark such a group `virtual_keyboard = true` and kb-kill targets only that
  virtual device, never the physical one, so input-remapper can always
  (re)grab the physical device - including across a restart. Ordinary groups
  (the default) grab matching devices directly. See `_resolve_targets`.

Requires: python-evdev and read access to /dev/input/event*. The daemon runs as
root (the systemd service); `detect`/`monitor` therefore need `sudo`.
"""

import argparse
import ctypes
import errno
import json
import os
import pwd
import selectors
import signal
import socket
import struct
import sys
import time
import tomllib
from pathlib import Path

try:
    from evdev import (  # pyright: ignore[reportMissingImports]
        InputDevice,
        ecodes,
        list_devices,
    )
except ImportError:
    sys.stderr.write(
        "kb-kill: python-evdev is required. Install it from your distro's\n"
        "packages (pip is NOT the supported install method — the daemon runs as\n"
        "a root system service against the system interpreter):\n"
        "  Debian/Ubuntu : sudo apt install python3-evdev\n"
        "  Fedora        : sudo dnf install python3-evdev\n"
        "  Arch          : sudo pacman -S python-evdev\n"
    )
    sys.exit(1)


# --------------------------------------------------------------------------- #
# Modifier aliases
#
# A combo is written as `+`-joined tokens, e.g. "ctrl+alt+shift+k". Each token
# resolves to an "any-of" GROUP of acceptable keycodes; the combo matches when
# every group has at least one of its keycodes currently held.
#
# Bare modifier names match EITHER side; prefix with l/r to pin a side.
#
#   token                         matches (evdev KEY_*, code)
#   ----------------------------  -------------------------------------------
#   ctrl  / control               KEY_LEFTCTRL  (29)  or KEY_RIGHTCTRL  (97)
#   lctrl / rctrl                  left-only           / right-only
#   alt                           KEY_LEFTALT   (56)  or KEY_RIGHTALT  (100, AltGr)
#   lalt  / ralt                   left-only           / right-only
#   shift                         KEY_LEFTSHIFT (42)  or KEY_RIGHTSHIFT (54)
#   lshift / rshift                left-only           / right-only
#   super / meta / win / cmd      KEY_LEFTMETA  (125) or KEY_RIGHTMETA (126)
#   lsuper/lmeta / rsuper/rmeta    left-only           / right-only
#
# Any other token resolves to a single keycode: a letter a-z -> KEY_A..KEY_Z,
# a raw evdev name like KEY_SCROLLLOCK, or a numeric keycode.
# --------------------------------------------------------------------------- #
MODIFIER_ALIASES = {
    "ctrl": frozenset({ecodes.KEY_LEFTCTRL, ecodes.KEY_RIGHTCTRL}),
    "control": frozenset({ecodes.KEY_LEFTCTRL, ecodes.KEY_RIGHTCTRL}),
    "lctrl": frozenset({ecodes.KEY_LEFTCTRL}),
    "rctrl": frozenset({ecodes.KEY_RIGHTCTRL}),
    "alt": frozenset({ecodes.KEY_LEFTALT, ecodes.KEY_RIGHTALT}),
    "lalt": frozenset({ecodes.KEY_LEFTALT}),
    "ralt": frozenset({ecodes.KEY_RIGHTALT}),
    "altgr": frozenset({ecodes.KEY_RIGHTALT}),
    "shift": frozenset({ecodes.KEY_LEFTSHIFT, ecodes.KEY_RIGHTSHIFT}),
    "lshift": frozenset({ecodes.KEY_LEFTSHIFT}),
    "rshift": frozenset({ecodes.KEY_RIGHTSHIFT}),
    "super": frozenset({ecodes.KEY_LEFTMETA, ecodes.KEY_RIGHTMETA}),
    "meta": frozenset({ecodes.KEY_LEFTMETA, ecodes.KEY_RIGHTMETA}),
    "win": frozenset({ecodes.KEY_LEFTMETA, ecodes.KEY_RIGHTMETA}),
    "cmd": frozenset({ecodes.KEY_LEFTMETA, ecodes.KEY_RIGHTMETA}),
    "lsuper": frozenset({ecodes.KEY_LEFTMETA}),
    "lmeta": frozenset({ecodes.KEY_LEFTMETA}),
    "rsuper": frozenset({ecodes.KEY_RIGHTMETA}),
    "rmeta": frozenset({ecodes.KEY_RIGHTMETA}),
}


def _invoking_home() -> Path:
    """Home directory of the user who invoked us, even under sudo/pkexec.

    A root `kb-kill detect`/`monitor` run via sudo gets HOME=/root, so a plain
    Path.home() would miss the user's config and force an explicit --config.
    Recover the real user from SUDO_USER (sudo) or PKEXEC_UID (polkit) and take
    their home from the passwd db; fall back to Path.home() when unprivileged or
    when there's no caller to recover (e.g. a bare systemd service, which passes
    --config anyway).
    """
    if os.geteuid() == 0:
        name = os.environ.get("SUDO_USER")
        if not name:
            uid = os.environ.get("PKEXEC_UID", "")
            if uid.isdigit():
                try:
                    name = pwd.getpwuid(int(uid)).pw_name
                except KeyError:
                    name = None
        if name and name != "root":
            try:
                return Path(pwd.getpwnam(name).pw_dir)
            except KeyError:
                pass
    return Path.home()


_HOME = _invoking_home()
CONFIG_SEARCH = [
    _HOME / ".config" / "kb-kill" / "kb-kill.toml",
    _HOME / ".kb-kill",
    Path("/etc/kb-kill/kb-kill.toml"),
]

# No built-in default hotkey on purpose: a keyboard can only ever be disabled by
# a combo the user explicitly set, so a fresh/empty config has no shortcut that
# can kill a keyboard. Combos are still inherited top-level -> [groups.*]; what's
# gone is a module-level fallback when nobody set one (that would be a hidden
# shortcut). A group with a target but no resolvable combo is a config error.

# How often (seconds) to rescan for hotplugged / recreated devices. Also the
# backstop interval for re-checking the active seat user (the inotify watch on
# the seats dir makes switches near-instant; this only covers a missed event).
RESCAN_INTERVAL = 2.0

# Control-socket DoS bounds. The socket is connectable by any local user (the
# SO_PEERCRED uid is the real gate), so the bounds are per-uid as well as global.
MAX_CLIENTS = 16  # concurrent control connections (global)
# Per-uid cap, so one user cannot starve the global pool. A single active user's
# NORMAL footprint is already 2 persistent connections (kb-kill-push + kb-kill-tray
# each hold one for their whole lifetime), so this must sit comfortably above 2:
# during a redeploy/login both restart, and the daemon still holds each dying
# client's connection until it reaps the EOF on its next loop iteration, so uid N
# can transiently need old-push + old-tray + new-push + new-tray = 4 at once. Set
# to 8 (push+tray, plus restart overlap, plus a stray/dev pusher) — still half the
# global pool. A cap of 2 here left zero headroom and wedged the reconnecting
# client in a refusal loop ("tray fails to connect" on install).
MAX_CONNS_PER_UID = 8
MAX_LINE = 65536  # bytes buffered per client before a newline; drop if exceeded
# (a full set_config TOML payload, JSON-escaped, must fit)
HANDSHAKE_SECONDS = 10  # drop a connection that sends no valid command in this long

# logind exposes the foreground session's user per seat here, as ACTIVE_UID=.
# We read this file (systemd marks it "do not parse", so we parse defensively and
# tolerate any field being absent) rather than dlopen libsystemd for
# sd_seat_get_active(), which would risk tripping MemoryDenyWriteExecute.
SEATS_DIR = "/run/systemd/seats"

# inotify event masks (we only need "something in the seats dir changed").
_IN_MODIFY = 0x00000002
_IN_CLOSE_WRITE = 0x00000008
_IN_MOVED_TO = 0x00000080
_IN_CREATE = 0x00000100
_IN_DELETE = 0x00000200
_SEAT_MASK = _IN_MODIFY | _IN_CLOSE_WRITE | _IN_MOVED_TO | _IN_CREATE | _IN_DELETE

# Selector tag for the control socket's listening fd (devices use their path
# string as the tag; clients use ("client", conn); the seat inotify fd uses
# _SEATWATCH).
_LISTEN = object()
_SEATWATCH = object()


def control_socket_path() -> str:
    """Where the control socket lives.

    As the root system daemon it lives in /run/kb-kill (created by the unit's
    RuntimeDirectory=); when run unprivileged (e.g. for testing) it falls back to
    the user's runtime dir.
    """
    if os.geteuid() == 0:
        return "/run/kb-kill/control.sock"
    base = os.environ.get("XDG_RUNTIME_DIR")
    if base:
        return os.path.join(base, "kb-kill.sock")
    return f"/tmp/kb-kill-{os.getuid()}.sock"


def log(msg: str) -> None:
    sys.stderr.write(f"kb-kill: {msg}\n")
    sys.stderr.flush()


# --------------------------------------------------------------------------- #
# Active seat user (logind)
# --------------------------------------------------------------------------- #
def active_uids() -> set[int]:
    """Set of uids that own a *foreground* session, one per seat.

    Read from /run/systemd/seats/* (ACTIVE_UID=). This is how we decide whose
    pushed config governs the keyboard: only the user currently in control of a
    seat (graphical or TTY) is "live". Returns an empty set when logind exposes
    no seats (headless / container) - callers then fall back to idle.
    """
    uids = set()
    try:
        names = os.listdir(SEATS_DIR)
    except OSError:
        return uids
    for name in names:
        try:
            with open(os.path.join(SEATS_DIR, name)) as fh:
                for line in fh:
                    if line.startswith("ACTIVE_UID="):
                        val = line.strip().split("=", 1)[1]
                        if val.isdigit():
                            uids.add(int(val))
                        break
        except OSError:
            continue
    return uids


class SeatWatch:
    """inotify watch on the seats dir so active-user switches are near-instant.

    Pure-ctypes over libc (no extra shared object is dlopen'd, so this stays
    clear of MemoryDenyWriteExecute; inotify_init1/add_watch/read are all in the
    unit's @system-service syscall set). Best-effort: if inotify is unavailable
    the daemon still re-checks the active user every RESCAN_INTERVAL.
    """

    def __init__(self) -> None:
        self.fd = -1
        try:
            libc = ctypes.CDLL(None, use_errno=True)
            fd = libc.inotify_init1(os.O_NONBLOCK | os.O_CLOEXEC)
            if fd < 0:
                raise OSError(ctypes.get_errno(), "inotify_init1")
            wd = libc.inotify_add_watch(fd, SEATS_DIR.encode(), _SEAT_MASK)
            if wd < 0:
                os.close(fd)
                raise OSError(ctypes.get_errno(), "inotify_add_watch")
            self.fd = fd
        except (OSError, AttributeError) as e:
            log(
                f"seat inotify unavailable ({e}); polling active user every "
                f"{RESCAN_INTERVAL:g}s instead"
            )

    def drain(self) -> None:
        """Consume pending events; their content is irrelevant (we just re-read
        the seat files afterwards)."""
        if self.fd < 0:
            return
        try:
            while True:
                if not os.read(self.fd, 4096):
                    break
        except OSError:
            pass

    def close(self) -> None:
        if self.fd >= 0:
            try:
                os.close(self.fd)
            except OSError:
                pass
            self.fd = -1


class ConfigError(Exception):
    pass


# --------------------------------------------------------------------------- #
# Config
# --------------------------------------------------------------------------- #
class Group:
    """One target set with its own kill/wake hotkeys."""

    def __init__(
        self,
        name: str,
        keyboards: list[str],
        kill_combo: list[frozenset[int]],
        wake_combo: list[frozenset[int]],
        virtual_keyboard: bool,
        kill_raw: str,
        wake_raw: str,
    ) -> None:
        self.name = name  # label for logs/detect
        self.keyboards = keyboards  # lowercase substrings
        self.kill_combo = kill_combo
        self.wake_combo = wake_combo
        self.virtual_keyboard = virtual_keyboard
        self.kill_raw = kill_raw  # original strings (for display)
        self.wake_raw = wake_raw
        # runtime state (managed by KbKill)
        self.targets: dict[str, InputDevice] = {}  # path -> InputDevice
        self.killed = False


class Config:
    def __init__(self, groups: list[Group], source: str) -> None:
        self.groups = groups
        self.source = source  # where it came from (path or "uid N")


def _parse_token(token: str) -> frozenset[int]:
    """Resolve one combo token to a frozenset of acceptable keycodes."""
    t = token.strip().lower()
    if not t:
        raise ConfigError("empty key in combo")
    if t in MODIFIER_ALIASES:
        return MODIFIER_ALIASES[t]
    if len(t) == 1 and t.isalnum():
        name = f"KEY_{t.upper()}"
        code = getattr(ecodes, name, None)
        if code is not None:
            return frozenset({code})
    # raw evdev name, e.g. KEY_SCROLLLOCK / SCROLLLOCK
    name = t.upper() if t.upper().startswith("KEY_") else f"KEY_{t.upper()}"
    code = getattr(ecodes, name, None)
    if code is not None:
        return frozenset({code})
    # numeric keycode
    if t.isdigit():
        return frozenset({int(t)})
    raise ConfigError(
        f"unknown key {token!r} (try ctrl/alt/shift/super, a-z, or a KEY_* name)"
    )


def _parse_combo(spec: str) -> list[frozenset[int]]:
    tokens = [tok for tok in spec.split("+") if tok.strip()]
    if not tokens:
        raise ConfigError(f"empty combo: {spec!r}")
    return [_parse_token(tok) for tok in tokens]


def find_config(explicit: str | None = None) -> Path:
    if explicit:
        p = Path(explicit).expanduser()
        if not p.is_file():
            raise ConfigError(f"config not found: {p}")
        return p
    env = os.environ.get("KB_KILL_CONFIG")
    if env:
        p = Path(env).expanduser()
        if not p.is_file():
            raise ConfigError(f"$KB_KILL_CONFIG points at a missing file: {p}")
        return p
    for p in CONFIG_SEARCH:
        # ~/.kb-kill may be a directory holding kb-kill.toml
        if p.is_dir():
            inner = p / "kb-kill.toml"
            if inner.is_file():
                return inner
        elif p.is_file():
            return p
    raise ConfigError(
        "no config file found. Create ~/.config/kb-kill/kb-kill.toml with:\n"
        '  keyboards  = "AT Translated Set 2 keyboard"\n'
        '  kill_combo = "ctrl+alt+shift+k"\n'
        '  wake_combo = "ctrl+alt+shift+u"'
    )


# Keys allowed in a group table / the top-level default group.
_GROUP_KEYS = {"keyboards", "kill_combo", "wake_combo", "virtual_keyboard"}


def _as_keyboards(value: object, where: str) -> list[str]:
    """Coerce the `keyboards` value (string or list of strings) to a list of
    lowercased substrings."""
    if isinstance(value, str):
        value = [value]
    if not isinstance(value, list) or not all(isinstance(v, str) for v in value):
        raise ConfigError(f"{where}: 'keyboards' must be a string or list of strings")
    kbs = [v.strip().lower() for v in value if v.strip()]
    if not kbs:
        raise ConfigError(f"{where}: 'keyboards' is empty")
    return kbs


def _build_group(name: str, table: dict, defaults: dict, where: str) -> Group:
    """Build a Group from a TOML table, inheriting unset combos from the
    top-level defaults. There is no built-in fallback: a group with a target
    keyboard but no kill_combo/wake_combo (here or inherited) is an error, so no
    keyboard can ever be disabled by a hotkey the user didn't explicitly set."""
    for key in table:
        if key not in _GROUP_KEYS:
            log(f"warning: {where}: unknown key {key!r} (ignored)")

    kbs = _as_keyboards(table["keyboards"], where)
    kill_raw = table.get("kill_combo", defaults["kill_combo"])
    wake_raw = table.get("wake_combo", defaults["wake_combo"])
    # virtual_keyboard describes one keyboard's nature, so it is per-group only
    # (default false) and never inherited from the top-level defaults.
    virtual = table.get("virtual_keyboard", False)
    if not isinstance(virtual, bool):
        raise ConfigError(f"{where}: 'virtual_keyboard' must be true or false")
    for label, val in (("kill_combo", kill_raw), ("wake_combo", wake_raw)):
        if val is None:
            raise ConfigError(
                f"{where}: '{label}' is required (no built-in default) — a "
                "keyboard can only be disabled by a combo you set explicitly."
            )
    if not isinstance(kill_raw, str) or not isinstance(wake_raw, str):
        raise ConfigError(f"{where}: 'kill_combo'/'wake_combo' must be strings")
    try:
        kill_combo = _parse_combo(kill_raw)
        wake_combo = _parse_combo(wake_raw)
    except ConfigError as e:
        raise ConfigError(f"{where}: {e}")
    return Group(name, kbs, kill_combo, wake_combo, virtual, kill_raw, wake_raw)


def parse_config(doc: dict, source: str) -> Config:
    """Build a Config from an already-parsed TOML document.

    Shared by load_config (a file, for detect/monitor and `-c` dev runs) and
    load_config_text (the TOML pushed over the control socket). Authorization is
    not carried in the config: the daemon binds each pushed config to the
    SO_PEERCRED uid that pushed it.
    """
    if not isinstance(doc, dict):
        raise ConfigError(f"{source}: top level must be a table")

    # Top-level keys form the default group (if they include `keyboards`) and
    # supply defaults inherited by [groups.*].
    sections = doc.pop("groups", {})
    if not isinstance(sections, dict):
        raise ConfigError(f"{source}: 'groups' must be a table ([groups.<name>])")

    # No module-level fallback: an unset combo stays None and is inherited by
    # [groups.*]; if nothing sets it, _build_group rejects the group rather than
    # conjuring a hidden default hotkey.
    defaults = {
        "kill_combo": doc.get("kill_combo"),
        "wake_combo": doc.get("wake_combo"),
    }

    groups = []
    if "keyboards" in doc:
        groups.append(_build_group("default", doc, defaults, f"{source} [top-level]"))
    else:
        # No top-level group: validate stray top-level keys are known defaults.
        for key in doc:
            if key not in _GROUP_KEYS:
                log(f"warning: {source}: unknown top-level key {key!r} (ignored)")

    for name, table in sections.items():
        if not isinstance(table, dict):
            raise ConfigError(f"{source}: [groups.{name}] must be a table")
        if "keyboards" not in table:
            raise ConfigError(f"{source}: [groups.{name}] is missing 'keyboards'")
        groups.append(_build_group(name, table, defaults, f"{source} [groups.{name}]"))

    if not groups:
        # An empty config is VALID and INERT: with no group there is no target
        # and no kill/wake combo, so the daemon only monitors and can never grab
        # a keyboard. This is the shipped default — a user must explicitly add a
        # group (top-level 'keyboards = ...' and/or a [groups.<name>] table)
        # before any hotkey can disable a keyboard.
        log(
            f"{source}: no groups defined — inert (monitor only, nothing can be killed)"
        )
    return Config(groups, source)


def load_config(explicit: str | None = None) -> Config:
    """Load a config from a file (detect/monitor and `-c` dev runs)."""
    path = find_config(explicit)
    try:
        with open(path, "rb") as fh:
            doc = tomllib.load(fh)
    except tomllib.TOMLDecodeError as e:
        raise ConfigError(f"{path}: invalid TOML: {e}")
    except OSError as e:
        raise ConfigError(f"{path}: {e}")
    return parse_config(doc, str(path))


def load_config_text(text: str, source: str) -> Config:
    """Load a config from TOML text pushed over the control socket."""
    try:
        doc = tomllib.loads(text)
    except tomllib.TOMLDecodeError as e:
        raise ConfigError(f"{source}: invalid TOML: {e}")
    except (TypeError, ValueError) as e:
        raise ConfigError(f"{source}: {e}")
    return parse_config(doc, source)


# --------------------------------------------------------------------------- #
# Device helpers
# --------------------------------------------------------------------------- #
def is_keyboard(dev: InputDevice) -> bool:
    """True for real typing keyboards (filters mice, power buttons, etc.)."""
    keys = dev.capabilities().get(ecodes.EV_KEY, [])
    return ecodes.KEY_A in keys and ecodes.KEY_Z in keys and ecodes.KEY_ENTER in keys


def is_virtual(dev: InputDevice) -> bool:
    """True for uinput / forwarded devices (e.g. input-remapper output)."""
    phys = (dev.phys or "").lower()
    name = (dev.name or "").lower()
    return "uinput" in phys or "forwarded" in name or "input-remapper" in name


def open_keyboards() -> dict[str, InputDevice]:
    """Return {path: InputDevice} for every readable keyboard."""
    found = {}
    for path in list_devices():
        try:
            dev = InputDevice(path)
        except OSError:
            continue
        if is_keyboard(dev):
            found[path] = dev
        else:
            dev.close()
    return found


def combo_held(combo: list[frozenset[int]], pressed: set[int]) -> bool:
    """True when every token group has >=1 of its keycodes in `pressed`."""
    return all(group & pressed for group in combo)


# --------------------------------------------------------------------------- #
# Service
# --------------------------------------------------------------------------- #
class KbKill:
    def __init__(self, config: Config | None = None) -> None:
        self.sel = selectors.DefaultSelector()
        self.devices: dict[str, InputDevice] = {}  # path -> InputDevice (monitored)
        self.pressed: dict[str, set[int]] = {}  # path -> set[int]
        self.grabbed: set[str] = set()  # paths currently EVIOCGRAB'd by us
        self.running = True
        self.need_rescan = False

        # Pure-push model: the daemon starts with no config and is told what to
        # do over the control socket. `pushed[uid]` holds the Config most
        # recently pushed by each uid; only the config of the uid that currently
        # controls a seat (active_uids()) is *live* and governs the keyboard.
        self.pushed: dict[int, Config] = {}  # uid -> Config (dropped on disconnect)
        self.live_uid: int | None = None  # uid whose config is governing, or None
        self.groups: list[Group] = []  # the live config's groups (empty when idle)

        # `-c PATH` dev mode: a file config forced live, bypassing seat
        # arbitration (so the daemon is usable for ad-hoc testing without a
        # pusher). Treated as if the invoking user pushed it and is always active.
        self.forced = config is not None
        if config is not None:
            self.pushed[os.getuid()] = config
            self.live_uid = os.getuid()
            self.groups = config.groups

        # control socket (now mandatory: it is how config arrives)
        self._listen: socket.socket | None = None
        self._sock_path: str | None = None
        # conn -> {"buf": bytes, "uid": int, "born": monotonic, "hello": bool}
        self.clients: dict[socket.socket, dict] = {}
        self._last_sig: tuple | None = None
        # seats inotify watch (best-effort; falls back to periodic polling)
        self._seatwatch: SeatWatch | None = None

    # -- device name matching ------------------------------------------------ #
    @staticmethod
    def _name_matches(group: Group, name: str | None) -> bool:
        if "*" in group.keyboards:  # wildcard: match every keyboard
            return True
        low = (name or "").lower()
        return any(sub in low for sub in group.keyboards)

    def _resolve_targets(self, group: Group) -> dict[str, InputDevice]:
        """Pick the devices to grab for a group.

        For a `virtual_keyboard` group (one fronted by an input-remapper
        "forwarded" device), target only the virtual device(s) and never the
        physical keyboard, so input-remapper can always keep/regrab the physical
        device. For an ordinary group, grab whatever matches directly.
        """
        matched = {
            p: d for p, d in self.devices.items() if self._name_matches(group, d.name)
        }
        if group.virtual_keyboard:
            return {p: d for p, d in matched.items() if is_virtual(d)}
        return matched

    # -- device lifecycle ---------------------------------------------------- #
    def _add_device(self, path: str, dev: InputDevice) -> None:
        self.devices[path] = dev
        self.pressed[path] = set(dev.active_keys())
        self.sel.register(dev, selectors.EVENT_READ, path)

    def _remove_device(self, path: str) -> None:
        dev = self.devices.pop(path, None)
        if dev is not None:
            try:
                self.sel.unregister(dev)
            except (KeyError, ValueError):
                pass
            try:
                dev.close()
            except OSError:
                pass
        self.pressed.pop(path, None)
        for group in self.groups:
            group.targets.pop(path, None)
        self.grabbed.discard(path)

    def rescan(self) -> None:
        self.need_rescan = False
        current = open_keyboards()

        # Drop devices that vanished.
        for path in list(self.devices):
            if path not in current:
                log(f"device gone: {path}")
                self._remove_device(path)

        # Add newly appeared devices.
        for path, dev in current.items():
            if path in self.devices:
                dev.close()  # already monitored; discard the duplicate handle
            else:
                self._add_device(path, dev)
                log(f"watching: {path} ({dev.name})")

        for group in self.groups:
            group.targets = self._resolve_targets(group)
        self._reconcile_grabs()

    # -- live config (which pushed config governs the keyboard) -------------- #
    def _install_groups(self, groups: list[Group], preserve: dict[str, bool]) -> None:
        """Make `groups` the live set, releasing any prior grab first.

        We unconditionally ungrab everything before switching so a grab can never
        outlive the config that asked for it (the core no-lockout invariant). New
        groups start with killed taken from `preserve` (name -> killed), default
        False -- so a session switch (preserve={}) always lands AWAKE: a
        backgrounded user can never pre-arm a kill that fires on the incoming
        user or the login greeter. A re-push from the live uid passes its current
        killed map so a config edit doesn't surprise-enable/disable a keyboard.
        """
        for path in list(self.grabbed):
            self._ungrab(path)
        for g in groups:
            g.killed = preserve.get(g.name, False)
        self.groups = groups
        for g in self.groups:
            g.targets = self._resolve_targets(g)
        self._reconcile_grabs()
        self._last_sig = None  # force a fresh state broadcast

    def _set_live(self, uid: int | None) -> None:
        """Switch which uid's pushed config governs the keyboard (starts awake)."""
        self.live_uid = uid
        cfg = self.pushed.get(uid) if uid is not None else None
        self._install_groups(cfg.groups if cfg else [], preserve={})
        if cfg:
            log(
                f"live config: uid {uid} -> {len(self.groups)} group(s) "
                f"[{', '.join(g.name for g in self.groups)}]"
            )
        else:
            log("live config: none (idle) - no active user has pushed a config")

    def _reevaluate_live(self) -> None:
        """Pick the live uid from the active seat user(s) and swap if it changed.

        Live uid = an active-seat uid that has pushed a config (deterministic by
        lowest uid when several seats are active). None -> idle. `-c` dev mode is
        pinned live and never re-evaluated.
        """
        if self.forced:
            return
        active = active_uids()
        desired = next((uid for uid in sorted(active) if uid in self.pushed), None)
        if desired != self.live_uid:
            self._set_live(desired)

    def _on_set_config(self, uid: int, text: str) -> None:
        """Handle a set_config push from `uid`: store it, apply if it's live."""
        try:
            cfg = load_config_text(text, f"uid {uid}")
        except ConfigError as e:
            log(f"rejected config from uid {uid}: {e}")
            return
        self.pushed[uid] = cfg
        if uid == self.live_uid:
            # The live user edited their config: re-apply, preserving killed state.
            preserve = {g.name: g.killed for g in self.groups}
            self._install_groups(cfg.groups, preserve)
            log(f"live config updated by uid {uid}: {len(self.groups)} group(s)")
        else:
            # A (possibly newly-active) user pushed: maybe it should go live now.
            self._reevaluate_live()

    # -- grab / ungrab ------------------------------------------------------- #
    def _grab(self, path: str) -> None:
        dev = self.devices.get(path)
        if dev is None or path in self.grabbed:
            return
        try:
            dev.grab()
            self.grabbed.add(path)
            log(f"grabbed (eating): {dev.name}")
        except OSError as e:
            if e.errno == errno.EBUSY:
                log(f"cannot grab {dev.name}: busy (held by another process)")
            else:
                log(f"cannot grab {dev.name}: {e}")

    def _ungrab(self, path: str) -> None:
        dev = self.devices.get(path)
        if dev is not None and path in self.grabbed:
            try:
                dev.ungrab()
            except OSError:
                pass
            log(f"released: {dev.name}")
        self.grabbed.discard(path)

    # -- state transitions --------------------------------------------------- #
    def _global_pressed(self) -> set[int]:
        """Union of keys held across every monitored device.

        Combos are matched against this union, not a single device, because
        input-remapper fans one physical keyboard's keys out across several
        virtual devices (e.g. remapped keys on "input-remapper keyboard", the
        rest on the "...forwarded" device). Per-device matching would never see
        the whole combo. The trade-off - holding a modifier on one keyboard and
        a key on another would match - is harmless for hotkeys this size.
        """
        held = set()
        for keys in self.pressed.values():
            held |= keys
        return held

    def _reconcile_grabs(self) -> None:
        """Make the set of grabbed devices match the union of every killed
        group's targets.

        A device is grabbed once no matter how many killed groups want it, and
        stays grabbed while any of them is killed. Grabbing a device that
        currently has keys held would swallow their key-ups and leave them stuck
        down at the OS, so we defer grabbing such a device until it is idle
        (unless it is already grabbed). Each key-up re-runs this, which is what
        eventually grabs a deferred device once released.
        """
        desired = set()
        for group in self.groups:
            if group.killed:
                desired.update(group.targets)

        for path in desired:
            if path in self.grabbed:
                continue
            if self.pressed.get(path):
                log(f"deferring grab of {self.devices[path].name} until keys released")
                continue
            self._grab(path)

        for path in list(self.grabbed):
            if path not in desired:
                self._ungrab(path)

    def _toggle_groups(self, held: set[int]) -> None:
        """Flip each group's killed state when its kill/wake combo is held."""
        for group in self.groups:
            if not group.killed:
                if combo_held(group.kill_combo, held):
                    group.killed = True
                    self._log_kill(group)
            elif combo_held(group.wake_combo, held):
                group.killed = False
                log(f"[{group.name}] WOKEN")

    def _log_kill(self, group: Group) -> None:
        # Lockout guard: warn (do not refuse) if killing the only keyboard(s)
        # present. A killed group can always wake itself, so this is never a
        # hard lockout.
        non_targets = [p for p in self.devices if p not in group.targets]
        if not group.targets:
            log(
                f"[{group.name}] kill: no target keyboard present yet "
                "(will grab when it appears)"
            )
        elif not non_targets:
            log(
                f"[{group.name}] warning: killing the only keyboard present "
                "(wake hotkey on it still works)"
            )
        log(f"[{group.name}] KILLED")

    # -- event handling ------------------------------------------------------ #
    def _process(self, path: str, event) -> None:
        if event.type != ecodes.EV_KEY:
            return
        pressed = self.pressed[path]
        if event.value == 1:  # key down
            pressed.add(event.code)
            self._toggle_groups(self._global_pressed())
        elif event.value == 0:  # key up
            pressed.discard(event.code)
        else:  # autorepeat (2) - ignore for combos
            return
        self._reconcile_grabs()

    def _read_device(self, dev: InputDevice, path: str) -> None:
        try:
            for event in dev.read():
                self._process(path, event)
        except OSError as e:
            if e.errno in (errno.ENODEV, errno.EBADF):
                log(f"device removed mid-read: {path}")
                self._remove_device(path)
                self.need_rescan = True
            elif e.errno != errno.EAGAIN:
                log(f"read error on {path}: {e}")

    # -- control socket (config push + tray) --------------------------------- #
    def _open_control_socket(self) -> None:
        """Open the control socket. MANDATORY now - it is how config arrives, so
        a failure to open is fatal (caller exits, systemd restarts us).

        The socket is connectable by any local user (mode 0666): a pusher must be
        able to bootstrap the daemon before any config (and therefore any allowed
        uid) exists. SO_PEERCRED is the real gate - see _accept_client /
        _apply_command - so this is not a weakening; it just moves the check from
        connect-time to per-command. No chown is needed (hence no CAP_CHOWN)."""
        path = control_socket_path()
        os.makedirs(os.path.dirname(path), exist_ok=True)
        if os.path.exists(path):
            os.unlink(path)
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.bind(path)
        os.chmod(path, 0o666)
        s.listen(MAX_CLIENTS)
        s.setblocking(False)
        self._listen = s
        self._sock_path = path
        self.sel.register(s, selectors.EVENT_READ, _LISTEN)
        log(
            f"control socket: {path} (any local user may connect; "
            "SO_PEERCRED gates every command)"
        )

    def _state_dict(self) -> dict:
        return {
            "type": "state",
            "groups": [
                {"name": g.name, "killed": g.killed, "targets": len(g.targets)}
                for g in self.groups
            ],
        }

    def _send(self, conn: socket.socket, obj: dict) -> None:
        try:
            conn.sendall((json.dumps(obj) + "\n").encode())
        except OSError:
            self._drop_client(conn)

    def _peer_uid(self, conn: socket.socket) -> int | None:
        try:
            creds = conn.getsockopt(
                socket.SOL_SOCKET, socket.SO_PEERCRED, struct.calcsize("3i")
            )
            _pid, uid, _gid = struct.unpack("3i", creds)
            return uid
        except OSError:
            return None

    def _accept_client(self) -> None:
        assert self._listen is not None  # registered in the selector => open
        try:
            conn, _ = self._listen.accept()
        except OSError:
            return
        uid = self._peer_uid(conn)
        if uid is None:
            conn.close()
            return
        # Per-uid cap so one user can't starve the global pool; then the global cap.
        if (
            uid != 0
            and sum(1 for c in self.clients.values() if c["uid"] == uid)
            >= MAX_CONNS_PER_UID
        ):
            log(f"control: per-uid connection cap reached for uid {uid}, refusing")
            conn.close()
            return
        if len(self.clients) >= MAX_CLIENTS:
            log("control: client cap reached, refusing connection")
            conn.close()
            return
        conn.setblocking(False)
        self.clients[conn] = {
            "buf": b"",
            "uid": uid,
            "born": time.monotonic(),
            "hello": False,
        }
        self.sel.register(conn, selectors.EVENT_READ, ("client", conn))
        # Send current state only to someone allowed to see it (the live user/root).
        if uid in (0, self.live_uid):
            self._send(conn, self._state_dict())

    def _drop_client(self, conn: socket.socket) -> None:
        try:
            self.sel.unregister(conn)
        except (KeyError, ValueError):
            pass
        info = self.clients.pop(conn, None)
        try:
            conn.close()
        except OSError:
            pass
        # If the disconnecting client was a pushing user's only remaining
        # connection, drop their pushed config and revert (idle or next active).
        # In forced (-c) dev mode the config is pinned and never dropped.
        if info is not None and not self.forced:
            uid = info["uid"]
            if uid != 0 and not any(c["uid"] == uid for c in self.clients.values()):
                if self.pushed.pop(uid, None) is not None:
                    log(f"uid {uid} disconnected; dropping its pushed config")
                    if uid == self.live_uid:
                        self._reevaluate_live()

    def _sweep_handshake(self) -> None:
        """Drop connections that never sent a valid command in time (anti-DoS)."""
        now = time.monotonic()
        for conn, info in list(self.clients.items()):
            if not info["hello"] and (now - info["born"]) > HANDSHAKE_SECONDS:
                log(
                    f"control: dropping idle connection from uid {info['uid']} "
                    "(no command within handshake window)"
                )
                self._drop_client(conn)

    def _read_client(self, conn: socket.socket) -> None:
        info = self.clients.get(conn)
        if info is None:
            return
        try:
            data = conn.recv(65536)
        except OSError:
            self._drop_client(conn)
            return
        if not data:
            self._drop_client(conn)
            return
        buf = info["buf"] + data
        *lines, rest = buf.split(b"\n")
        # DoS bound: drop a client that floods bytes without a newline.
        if len(rest) > MAX_LINE:
            log("control: dropping client (over-long line)")
            self._drop_client(conn)
            return
        info["buf"] = rest
        for line in lines:
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except ValueError:
                continue
            if not isinstance(obj, dict):
                continue
            info["hello"] = True
            self._apply_command(obj, conn, info["uid"])

    def _apply_command(self, obj: dict, conn: socket.socket, uid: int) -> None:
        cmd = obj.get("cmd")

        # set_config: accepted from ANY uid, stored under that uid; it only
        # governs the keyboard while that uid is the active seat user.
        if cmd == "set_config":
            text = obj.get("toml")
            if isinstance(text, str):
                self._on_set_config(uid, text)
            return

        # status: only the live user (or root) may read live state.
        if cmd == "status":
            if uid in (0, self.live_uid):
                self._send(conn, self._state_dict())
            return

        # kill/wake/toggle: only the user whose config is currently live (or root).
        if uid not in (0, self.live_uid):
            log(f"control: rejected {cmd!r} from uid {uid} (not the live user)")
            return
        group = next((g for g in self.groups if g.name == obj.get("group")), None)
        if group is None:
            return
        if cmd == "kill":
            group.killed = True
        elif cmd == "wake":
            group.killed = False
        elif cmd == "toggle":
            group.killed = not group.killed
        else:
            return
        log(f"[{group.name}] {'KILLED' if group.killed else 'WOKEN'} (via control)")
        self._reconcile_grabs()

    def _maybe_broadcast(self) -> None:
        sig = tuple((g.killed, len(g.targets)) for g in self.groups)
        if sig == self._last_sig:
            return
        self._last_sig = sig
        state = self._state_dict()
        for conn, info in list(self.clients.items()):
            if info["uid"] in (0, self.live_uid):
                self._send(conn, state)

    # -- main loop ----------------------------------------------------------- #
    def run(self) -> int:
        def _stop(signum: int, frame: object) -> None:
            raise KeyboardInterrupt

        signal.signal(signal.SIGTERM, _stop)

        # Mandatory: without the socket the daemon can never receive a config.
        try:
            self._open_control_socket()
        except OSError as e:
            log(f"FATAL: cannot open control socket: {e}")
            return 1

        if self.forced:
            assert self.live_uid is not None  # forced => live_uid set in __init__
            log(f"forced config (-c): {self.pushed[self.live_uid].source}")
        else:
            log("waiting for a config push from the active user's kb-kill-push")

        # Watch the seats dir so active-user switches apply near-instantly; the
        # periodic rescan re-checks as a backstop if inotify is unavailable.
        self._seatwatch = SeatWatch()
        if self._seatwatch.fd >= 0:
            self.sel.register(self._seatwatch.fd, selectors.EVENT_READ, _SEATWATCH)

        self.rescan()
        self._reevaluate_live()
        # Seed the broadcast signature so newly-connected clients get state only
        # via the initial send, not a spurious startup broadcast.
        self._last_sig = tuple((g.killed, len(g.targets)) for g in self.groups)

        last_scan = time.monotonic()
        try:
            while self.running:
                events = self.sel.select(timeout=RESCAN_INTERVAL)
                for key, _ in events:
                    tag = key.data
                    if tag is _LISTEN:
                        self._accept_client()
                    elif tag is _SEATWATCH:
                        self._seatwatch.drain()
                        self._reevaluate_live()
                    elif isinstance(tag, tuple) and tag[0] == "client":
                        self._read_client(tag[1])
                    else:
                        assert isinstance(tag, str)  # a device fd: data is its path
                        self._read_device(key.fileobj, tag)
                now = time.monotonic()
                if self.need_rescan or (now - last_scan) >= RESCAN_INTERVAL:
                    self.rescan()
                    self._reevaluate_live()  # backstop for a missed inotify event
                    self._sweep_handshake()
                    last_scan = now
                self._maybe_broadcast()
        except KeyboardInterrupt:
            pass
        finally:
            self.cleanup()
        return 0

    def cleanup(self) -> None:
        for path in list(self.grabbed):
            self._ungrab(path)
        for path in list(self.devices):
            self._remove_device(path)
        for conn in list(self.clients):
            self._drop_client(conn)
        if self._seatwatch is not None:
            try:
                self.sel.unregister(self._seatwatch.fd)
            except (KeyError, ValueError):
                pass
            self._seatwatch.close()
        if self._listen is not None:
            try:
                self.sel.unregister(self._listen)
            except (KeyError, ValueError):
                pass
            try:
                self._listen.close()
            except OSError:
                pass
            if self._sock_path and os.path.exists(self._sock_path):
                try:
                    os.unlink(self._sock_path)
                except OSError:
                    pass
        log("stopped; keyboards restored")


# --------------------------------------------------------------------------- #
# Commands
# --------------------------------------------------------------------------- #
def cmd_run(config: Config | None) -> int:
    # config is None for the normal service (config arrives via push); a file
    # config from `-c` is pinned live for ad-hoc dev testing.
    return KbKill(config).run()


def cmd_detect(config: Config) -> int:
    print("=== kb-kill detect ===")
    print(f"session : {os.environ.get('XDG_SESSION_TYPE', 'unknown')}")
    print(f"config  : {config.source}")
    print()
    print("Groups:")
    if not config.groups:
        print("  (none) - config is INERT: kb-kill only monitors and can never")
        print("          disable a keyboard. Add a group (with kill/wake combos)")
        print("          to enable it; see the comments in kb-kill.toml.")
    for g in config.groups:
        print(f"  [{g.name}]  keyboards={g.keyboards}")
        print(
            f"  {'':9}kill={g.kill_raw}  wake={g.wake_raw}  "
            f"virtual_keyboard={g.virtual_keyboard}"
        )
    print()

    if os.geteuid() != 0:
        print("WARNING: not running as root - reading keyboards will fail.")
        print("  Re-run with sudo:  sudo kb-kill-daemon detect")
        print()

    devices = open_keyboards()
    if not devices:
        print("No keyboards found (permission problem?).")
        return 1

    svc = KbKill(config)
    svc.devices = devices
    svc.pressed = {p: set() for p in devices}
    for g in config.groups:
        g.targets = svc._resolve_targets(g)

    any_target = any(g.targets for g in config.groups)
    print("Keyboards:")
    for path in sorted(devices):
        dev = devices[path]
        kind = "virtual " if is_virtual(dev) else "physical"
        target_of = [g.name for g in config.groups if path in g.targets]
        matched_of = [g.name for g in config.groups if svc._name_matches(g, dev.name)]
        if target_of:
            mark = f"TARGET of {', '.join(target_of)} (grabbed when killed)"
        elif matched_of:
            mark = (
                f"matches {', '.join(matched_of)}, but skipped "
                "(virtual_keyboard=true ignores the physical device)"
            )
        else:
            mark = "monitored only (can trigger any hotkey)"
        print(f"  {path:24} [{kind}] {dev.name}")
        print(f"  {'':24}   {mark}")

    if config.groups and not any_target:
        print()
        print(
            "No target will be grabbed. A virtual_keyboard group needs its "
            "input-remapper\nforwarded device present; an ordinary group needs "
            "a matching keyboard."
        )
    for dev in devices.values():
        dev.close()
    return 0


def _keyname(code: int) -> str:
    name = ecodes.KEY.get(code, str(code))
    if isinstance(name, (list, tuple)):
        name = name[0]
    return name


def cmd_monitor(config: Config) -> int:
    """Print every key event with its device + keycode, and flag when the
    kill/wake combos match per-device or globally. Used to diagnose how
    input-remapper routes the target keyboard's keys."""
    devices = open_keyboards()
    if not devices:
        print("No keyboards found.")
        return 1

    sel = selectors.DefaultSelector()
    pressed: dict[str, set[int]] = {}
    for path, dev in devices.items():
        pressed[path] = set(dev.active_keys())
        sel.register(dev, selectors.EVENT_READ, path)

    print("Monitoring all keyboards. Press a group's kill/wake combo.")
    for g in config.groups:
        print(f"  [{g.name}] kill={g.kill_raw} wake={g.wake_raw}")
    print("Ctrl+C to stop.\n")
    try:
        while True:
            for key, _ in sel.select():
                path = key.data
                dev = devices[path]  # InputDevice (key.fileobj is loosely typed)
                try:
                    events = list(dev.read())
                except OSError:
                    continue
                for ev in events:
                    if ev.type != ecodes.EV_KEY:
                        continue
                    p = pressed[path]
                    if ev.value == 1:
                        p.add(ev.code)
                    elif ev.value == 0:
                        p.discard(ev.code)
                    action = {1: "down", 0: "up", 2: "rept"}.get(ev.value, "?")
                    short = dev.name[:34]
                    glob = set().union(*pressed.values()) if pressed else set()
                    flags = []
                    for g in config.groups:
                        if combo_held(g.kill_combo, glob):
                            flags.append(f"KILL[{g.name}]")
                        if combo_held(g.wake_combo, glob):
                            flags.append(f"WAKE[{g.name}]")
                    tag = ("  <<< " + " ".join(flags)) if flags else ""
                    print(f"{path:20} {short:34} {_keyname(ev.code):16} {action}{tag}")
    except KeyboardInterrupt:
        pass
    finally:
        for dev in devices.values():
            dev.close()
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="kb-kill-daemon",
        description="Disable/enable a target keyboard on a global hotkey.",
    )
    parser.add_argument(
        "command",
        nargs="?",
        default="run",
        choices=["run", "detect", "monitor"],
        help="run the service (default), detect keyboards, "
        "or monitor raw key events for debugging",
    )
    parser.add_argument(
        "-c",
        "--config",
        help="path to a config file. detect/monitor read it to "
        "show your setup; for `run` it pins that config live "
        "for ad-hoc testing (the service instead receives "
        "config from the active user via kb-kill-push).",
    )
    args = parser.parse_args(argv)

    # The service (`run` without -c) starts config-less and is fed by kb-kill-push.
    if args.command == "run" and not args.config:
        return cmd_run(None)

    try:
        config = load_config(args.config)
    except ConfigError as e:
        log(str(e))
        return 1

    if args.command == "detect":
        return cmd_detect(config)
    if args.command == "monitor":
        return cmd_monitor(config)
    return cmd_run(config)


if __name__ == "__main__":
    sys.exit(main())
